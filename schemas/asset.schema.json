{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.eq.solutions/service/asset/v1.json",
  "title": "Asset",
  "description": "A serviceable asset at a site (switchboard, UPS, generator, fire pump, AHU, etc). The atomic unit of EQ Service.",
  "type": "object",
  "x-eq-entity": "asset",
  "x-eq-module": "service",
  "x-eq-version": "1.0.0",
  "x-eq-table": "assets",
  "required": ["asset_id", "tenant_id", "site_id", "asset_type", "name"],
  "properties": {
    "asset_id": {
      "type": "string",
      "format": "uuid",
      "x-eq-source-aliases": ["id", "asset_id", "equipment_id", "tag_id"],
      "x-eq-required-on-import": false
    },
    "tenant_id": {
      "type": "string",
      "format": "uuid",
      "x-eq-system-managed": true
    },
    "external_id": {
      "type": ["string", "null"],
      "description": "Customer's tag/equipment number. Often physically labelled on the asset.",
      "x-eq-source-aliases": ["tag", "tag_number", "equipment_no", "asset_no", "asset_number", "ref", "code", "plant_no"],
      "maxLength": 64
    },
    "site_id": {
      "type": "string",
      "format": "uuid",
      "description": "Site this asset belongs to.",
      "x-eq-foreign-key": "site.site_id",
      "x-eq-fk-fuzzy-match-on": ["site.name", "site.code", "site.external_id"],
      "x-eq-source-aliases": ["site", "location", "site_name", "site_code"]
    },
    "parent_asset_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "If this asset is part of a hierarchy (e.g. a breaker inside a switchboard), the parent.",
      "x-eq-foreign-key": "asset.asset_id",
      "x-eq-source-aliases": ["parent", "parent_tag", "located_in", "part_of"]
    },
    "asset_type": {
      "type": "string",
      "description": "Category of asset. Drives default service schedules and inspection forms.",
      "x-eq-source-aliases": ["type", "category", "equipment_type", "kind", "classification"],
      "x-eq-suggested-values": [
        "switchboard",
        "ups",
        "generator",
        "transformer",
        "ats",
        "rpp",
        "pdu",
        "battery_string",
        "ahu",
        "crac",
        "chiller",
        "fire_pump",
        "fire_panel",
        "smoke_detector",
        "emergency_light",
        "exit_sign",
        "rcd",
        "thermal_imaging_point",
        "earth_test_point",
        "other"
      ],
      "x-eq-enum-aliases": {
        "switchboard": ["sb", "msb", "main switchboard", "dist board", "db"],
        "ups": ["uninterruptible power supply", "u.p.s."],
        "ats": ["automatic transfer switch", "transfer switch"],
        "ahu": ["air handling unit", "air handler"],
        "crac": ["computer room air conditioner", "crah"],
        "rcd": ["residual current device", "earth leakage", "elcb"]
      }
    },
    "name": {
      "type": "string",
      "description": "Display name. Required.",
      "x-eq-source-aliases": ["asset_name", "description", "equipment_name"],
      "minLength": 1,
      "maxLength": 200
    },
    "make": {
      "type": ["string", "null"],
      "description": "Manufacturer.",
      "x-eq-source-aliases": ["manufacturer", "mfr", "brand", "make_brand"],
      "maxLength": 100
    },
    "model": {
      "type": ["string", "null"],
      "description": "Model number / designation.",
      "x-eq-source-aliases": ["model_no", "model_number", "model_name", "type_no"],
      "maxLength": 100
    },
    "serial_number": {
      "type": ["string", "null"],
      "x-eq-source-aliases": ["serial", "serial_no", "sn", "s_n", "serial #"],
      "maxLength": 100
    },
    "rating": {
      "type": ["string", "null"],
      "description": "Capacity/rating as a free text string. e.g. '500kVA', '200A', '1600L/min'.",
      "x-eq-source-aliases": ["capacity", "size", "rating_capacity", "kva", "amps"],
      "maxLength": 100
    },
    "install_date": {
      "type": ["string", "null"],
      "format": "date",
      "x-eq-source-aliases": ["installed", "installation_date", "commissioned", "comm_date"],
      "x-eq-coerce": "date"
    },
    "warranty_expires": {
      "type": ["string", "null"],
      "format": "date",
      "x-eq-source-aliases": ["warranty_end", "warranty_expiry", "warranty_until"],
      "x-eq-coerce": "date"
    },
    "criticality": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "Operational criticality. Drives SLA tier and escalation.",
      "x-eq-source-aliases": ["priority", "importance", "tier", "risk_level"],
      "x-eq-enum-aliases": {
        "critical": ["1", "p1", "tier_1", "tier 1", "very high", "vh"],
        "high": ["2", "p2", "tier_2", "tier 2", "h"],
        "medium": ["3", "p3", "tier_3", "tier 3", "med", "m"],
        "low": ["4", "p4", "tier_4", "tier 4", "l"]
      },
      "default": "medium"
    },
    "service_schedule_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Reference to the service schedule template applied to this asset.",
      "x-eq-foreign-key": "service_schedule.schedule_id",
      "x-eq-source-aliases": ["schedule", "service_plan", "pm_schedule"]
    },
    "last_service_date": {
      "type": ["string", "null"],
      "format": "date",
      "x-eq-source-aliases": ["last_pm", "last_serviced", "last_inspection", "last_service"],
      "x-eq-coerce": "date"
    },
    "next_service_due": {
      "type": ["string", "null"],
      "format": "date",
      "x-eq-source-aliases": ["next_pm", "due_date", "next_due", "next_inspection"],
      "x-eq-coerce": "date"
    },
    "location_in_site": {
      "type": ["string", "null"],
      "description": "Free text location within the site, e.g. 'Level 2 Plant Room', 'MSB-A'.",
      "x-eq-source-aliases": ["location_detail", "room", "area", "where", "physical_location"]
    },
    "barcode": {
      "type": ["string", "null"],
      "description": "Barcode or QR code value for scan-based identification.",
      "x-eq-source-aliases": ["qr", "qr_code", "barcode_value"]
    },
    "active": {
      "type": "boolean",
      "x-eq-source-aliases": ["is_active", "current", "status", "in_service"],
      "x-eq-coerce": "boolean",
      "default": true
    },
    "notes": {
      "type": ["string", "null"],
      "x-eq-source-aliases": ["comment", "comments", "remarks", "note", "description"],
      "maxLength": 4000
    },
    "imported_at": { "type": ["string", "null"], "format": "date-time", "x-eq-system-managed": true },
    "imported_from": { "type": ["string", "null"], "x-eq-system-managed": true }
  },
  "x-eq-cross-field-rules": [
    {
      "id": "next_after_last",
      "rule": "next_service_due == null OR last_service_date == null OR next_service_due > last_service_date",
      "message": "Next service due is not after last service date."
    },
    {
      "id": "warranty_after_install",
      "rule": "warranty_expires == null OR install_date == null OR warranty_expires > install_date",
      "message": "Warranty expiry is before install date."
    }
  ],
  "x-eq-import-hints": {
    "description": "Asset registers come in wildly different shapes. The header row is rarely on row 1.",
    "common_sources": [
      {
        "name": "Existing PM contractor's register",
        "typical_columns": ["Tag", "Description", "Manufacturer", "Model", "Serial", "Last PM", "Next PM", "Frequency"],
        "watchouts": ["Often has merged header rows", "Frequency may be coded ('M', 'Q', '6M', 'A') — may need separate schedule field"]
      },
      {
        "name": "Client's facilities export (head office originated)",
        "typical_columns": ["Asset No", "Building", "Floor", "Room", "Asset Description", "Make/Model", "Install Date"],
        "watchouts": ["Building/Floor/Room often need concatenating into location_in_site", "Make/Model may be combined — needs splitting"]
      },
      {
        "name": "Hand-built electrical asset list",
        "typical_columns": ["Switchboard", "Circuit", "Description", "Amps"],
        "watchouts": ["Each row is often a sub-asset of a switchboard — parent_asset_id must be inferred from grouping"]
      }
    ]
  }
}
