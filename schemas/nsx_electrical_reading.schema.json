{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.eq.solutions/service/nsx-electrical-reading/v1.json",
  "title": "NSX Electrical Reading",
  "description": "A quantitative electrical reading from the electrical-test step of an NSX (MCCB) test. Sibling of acb_electrical_reading.",
  "type": "object",
  "x-eq-entity": "nsx_electrical_reading",
  "x-eq-module": "service",
  "x-eq-version": "1.0.0",
  "x-eq-table": "nsx_test_readings",
  "x-eq-table-discriminator": { "column": "unit", "predicate": "unit IS NOT NULL" },
  "required": ["reading_id", "tenant_id", "nsx_test_id", "label", "value"],
  "properties": {
    "reading_id": {
      "type": "string",
      "format": "uuid",
      "x-eq-source-aliases": ["id", "reading_id"],
      "x-eq-required-on-import": false
    },
    "tenant_id": {
      "type": "string",
      "format": "uuid",
      "x-eq-system-managed": true
    },
    "nsx_test_id": {
      "type": "string",
      "format": "uuid",
      "x-eq-foreign-key": "nsx_test.nsx_test_id",
      "x-eq-source-aliases": ["test_id", "nsx_test"]
    },
    "label": {
      "type": "string",
      "x-eq-source-aliases": ["measurement", "test_label", "description", "reading_name"],
      "minLength": 1,
      "maxLength": 200
    },
    "value": {
      "type": "string",
      "description": "Recorded reading as text. Preserves significant digits and notations like '>2000', 'OL'.",
      "x-eq-source-aliases": ["reading", "measured_value", "result", "measurement_value"],
      "minLength": 1,
      "maxLength": 200
    },
    "unit": {
      "type": ["string", "null"],
      "x-eq-source-aliases": ["units", "uom"],
      "maxLength": 50
    },
    "is_pass": {
      "type": ["boolean", "null"],
      "x-eq-source-aliases": ["pass", "passed", "in_range"],
      "x-eq-coerce": "boolean"
    },
    "sort_order": {
      "type": "integer",
      "x-eq-source-aliases": ["order", "sequence", "seq"],
      "x-eq-coerce": "number",
      "minimum": 0,
      "default": 0
    },
    "notes": {
      "type": ["string", "null"],
      "x-eq-source-aliases": ["comment", "comments", "remarks", "note"],
      "maxLength": 2000
    },
    "imported_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "x-eq-system-managed": true
    },
    "imported_from": {
      "type": ["string", "null"],
      "x-eq-system-managed": true
    }
  }
}
