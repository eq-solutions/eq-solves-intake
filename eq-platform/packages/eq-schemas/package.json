{
  "name": "@eq/schemas",
  "version": "0.0.1",
  "private": true,
  "description": "Canonical EQ JSON Schemas + generated TypeScript types and Zod validators.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*.json": "./src/schemas/*.json"
  },
  "files": [
    "dist",
    "src/schemas"
  ],
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "generate:sql": "tsx scripts/generate-sql.ts",
    "schemas:lint": "tsx scripts/lint-schemas.ts",
    "build": "pnpm generate && tsup",
    "prepare": "pnpm generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "json-schema-to-typescript": "15.0.4",
    "json-schema-to-zod": "2.6.1",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
