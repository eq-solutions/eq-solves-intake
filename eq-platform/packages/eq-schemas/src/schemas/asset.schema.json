{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.eq.solutions/service/asset/v1.json",
  "title": "Asset",
  "description": "A serviceable asset at a site (switchboard, UPS, generator, fire pump, AHU, etc). The atomic unit of EQ Service.",
  "type": "object",
  "x-eq-entity": "asset",
  "x-eq-module": "service",
  "x-eq-version": "1.0.0",
  "x-eq-table": "assets",
  "required": ["asset_id", "tenant_id", "site_id", "asset_type", "name"],
  "properties": {
    "asset_id": {
      "type": "string",
      "format": "uuid",
      "x-eq-source-aliases": ["id", "asset_id", "equipment_id", "tag_id", "item_id", "asset_uuid", "internal_id"],
      "x-eq-required-on-import": false
    },
    "tenant_id": {
      "type": "string",
      "format": "uuid",
      "x-eq-system-managed": true
    },
    "external_id": {
      "type": ["string", "null"],
      "description": "Customer's tag/equipment number. Often physically labelled on the asset.",
      "x-eq-source-aliases": ["tag", "tag_number", "tag_no", "equipment_no", "equipment_number", "asset_no", "asset_number", "asset_code", "asset_tag", "ref", "code", "plant_no", "plant_number", "plant_id", "item_code", "item_number", "item_no", "sku", "customer_tag", "equipment_tag", "facility_id"],
      "maxLength": 64
    },
    "site_id": {
      "type": "string",
      "format": "uuid",
      "description": "Site this asset belongs to.",
      "x-eq-foreign-key": "site.site_id",
      "x-eq-fk-fuzzy-match-on": ["site.name", "site.code", "site.external_id"],
      "x-eq-source-aliases": ["site", "location", "site_name", "site_code", "facility", "facility_name", "premises", "property", "address"]
    },
    "parent_asset_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "If this asset is part of a hierarchy (e.g. a breaker inside a switchboard), the parent.",
      "x-eq-foreign-key": "asset.asset_id",
      "x-eq-source-aliases": ["parent", "parent_tag", "located_in", "part_of", "parent_id", "parent_equipment", "parent_asset", "contained_in", "mounted_on", "housed_in", "parent_ref"]
    },
    "asset_type": {
      "type": "string",
      "description": "Category of asset. Drives default service schedules and inspection forms.",
      "x-eq-source-aliases": ["type", "category", "equipment_type", "kind", "classification", "item_type", "asset_class", "asset_category", "equipment_class", "category_name", "equipment_category", "asset_kind", "type_of_asset"],
      "x-eq-suggested-values": [
        "switchboard",
        "ups",
        "generator",
        "transformer",
        "ats",
        "rpp",
        "pdu",
        "battery_string",
        "ahu",
        "crac",
        "chiller",
        "fire_pump",
        "fire_panel",
        "smoke_detector",
        "emergency_light",
        "exit_sign",
        "rcd",
        "thermal_imaging_point",
        "earth_test_point",
        "other"
      ],
      "x-eq-enum-aliases": {
        "switchboard": ["sb", "msb", "main switchboard", "dist board", "db"],
        "ups": ["uninterruptible power supply", "u.p.s."],
        "ats": ["automatic transfer switch", "transfer switch"],
        "ahu": ["air handling unit", "air handler"],
        "crac": ["computer room air conditioner", "crah"],
        "rcd": ["residual current device", "earth leakage", "elcb"]
      }
    },
    "name": {
      "type": "string",
      "description": "Display name. Required.",
      "x-eq-source-aliases": ["asset_name", "description", "equipment_name", "title", "item_name", "item_description", "item description", "item", "asset_description", "equipment_description", "label", "asset_label", "plant_name", "part_description", "device_name"],
      "minLength": 1,
      "maxLength": 200
    },
    "make": {
      "type": ["string", "null"],
      "description": "Manufacturer.",
      "x-eq-source-aliases": ["manufacturer", "mfr", "brand", "make_brand", "oem", "vendor", "manufacturer_name", "mfr_name", "maker", "supplier_brand"],
      "maxLength": 100
    },
    "model": {
      "type": ["string", "null"],
      "description": "Model number / designation.",
      "x-eq-source-aliases": ["model_no", "model_number", "model_name", "type_no", "part_number", "part_no", "model_code", "product_code", "product_number", "product_no", "product_name", "catalogue_no", "catalog_no"],
      "maxLength": 100
    },
    "serial_number": {
      "type": ["string", "null"],
      "x-eq-source-aliases": ["serial", "serial_no", "sn", "s_n", "s/n", "serial #", "mfr_serial", "manufacturer_serial", "serial_id", "factory_serial", "unit_serial"],
      "maxLength": 100
    },
    "rating": {
      "type": ["string", "null"],
      "description": "Capacity/rating as a free text string. e.g. '500kVA', '200A', '1600L/min'.",
      "x-eq-source-aliases": ["capacity", "size", "rating_capacity", "kva", "amps", "kw", "kva_rating", "watts", "voltage", "current", "power", "va", "hp", "btu", "lpm", "l_min", "output_rating", "capacity_rating", "electrical_rating", "motor_rating", "duty"],
      "maxLength": 100
    },
    "install_date": {
      "type": ["string", "null"],
      "format": "date",
      "x-eq-source-aliases": ["installed", "installation_date", "commissioned", "comm_date", "date_installed", "date_commissioned", "fitted_date", "date_fitted", "energised", "energized", "date_energised", "date_energized", "in_service_date", "commissioning_date", "first_used"],
      "x-eq-coerce": "date"
    },
    "warranty_expires": {
      "type": ["string", "null"],
      "format": "date",
      "x-eq-source-aliases": ["warranty_end", "warranty_expiry", "warranty_until", "warranty_expiration", "warranty_to", "guarantee_until", "guarantee_expiry", "warranty_finish", "warranty_date", "warranty_ends"],
      "x-eq-coerce": "date"
    },
    "criticality": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "Operational criticality. Drives SLA tier and escalation.",
      "x-eq-source-aliases": ["priority", "importance", "tier", "risk_level", "severity", "business_criticality", "criticality_level", "criticality_rating", "risk", "impact_level"],
      "x-eq-enum-aliases": {
        "critical": ["1", "p1", "tier_1", "tier 1", "very high", "vh"],
        "high": ["2", "p2", "tier_2", "tier 2", "h"],
        "medium": ["3", "p3", "tier_3", "tier 3", "med", "m"],
        "low": ["4", "p4", "tier_4", "tier 4", "l"]
      },
      "default": "medium"
    },
    "condition": {
      "type": "string",
      "enum": ["good", "fair", "poor", "needs_replacement", "unknown"],
      "description": "Current physical/operational state of the asset. Distinct from criticality (which measures importance, not state of repair).",
      "x-eq-source-aliases": ["state", "asset_condition", "physical_state", "current_condition", "condition_rating", "asset_state", "state_of_repair", "asset_health"],
      "x-eq-enum-aliases": {
        "good": ["g", "ok", "okay", "satisfactory", "sat", "pass", "healthy"],
        "fair": ["f", "average", "acceptable", "moderate"],
        "poor": ["p", "bad", "deteriorated", "deteriorating", "unsatisfactory", "unsat", "fail", "failing"],
        "needs_replacement": ["replace", "end_of_life", "eol", "for_replacement", "to_replace", "decommission"]
      },
      "default": "unknown"
    },
    "service_schedule_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Reference to the service schedule template applied to this asset.",
      "x-eq-foreign-key": "service_schedule.schedule_id",
      "x-eq-source-aliases": ["schedule", "service_plan", "pm_schedule", "pm_plan", "maintenance_plan", "service_schedule", "service_template", "pm_template", "schedule_name", "maintenance_schedule", "sla_schedule"]
    },
    "ppm_frequency": {
      "type": ["string", "null"],
      "description": "How often this asset is serviced. Free text — common values: '6-Monthly May/Nov', 'Annual', 'Quarterly', 'Monthly', or shorthand like 'M', 'Q', '6M', 'A'. Parsed into a formal service_schedule record at commit time when the schedule entity is the source of truth.",
      "x-eq-source-aliases": ["frequency", "service_interval", "pm_frequency", "maintenance_frequency", "service_cadence", "inspection_frequency", "pm_interval", "service_frequency", "maint_freq", "service_period", "ppm_frequency", "ppm interval"],
      "maxLength": 100
    },
    "last_service_date": {
      "type": ["string", "null"],
      "format": "date",
      "x-eq-source-aliases": ["last_pm", "last_serviced", "last_inspection", "last_service", "previous_service", "prev_service", "last_maintenance", "last_check", "last_test", "date_last_serviced", "last_pm_date", "last_inspection_date", "last_serviced_date"],
      "x-eq-coerce": "date"
    },
    "next_service_due": {
      "type": ["string", "null"],
      "format": "date",
      "x-eq-source-aliases": ["next_pm", "due_date", "next_due", "next_inspection", "next_service", "scheduled_service", "due", "next_maintenance", "service_due", "pm_due", "next_check", "next_test", "next_pm_date", "due_for_service", "next_service_date"],
      "x-eq-coerce": "date"
    },
    "location_in_site": {
      "type": ["string", "null"],
      "description": "Free text location within the site, e.g. 'Level 2 Plant Room', 'MSB-A'.",
      "x-eq-source-aliases": ["location_detail", "room", "area", "where", "physical_location", "building", "floor", "level", "zone", "position", "rack", "room_name", "plant_room", "sub_location", "exact_location", "room_number", "specific_location", "location_within_site"]
    },
    "barcode": {
      "type": ["string", "null"],
      "description": "Barcode or QR code value for scan-based identification.",
      "x-eq-source-aliases": ["qr", "qr_code", "barcode_value", "scan_code", "barcode_id", "bar_code", "qr_value", "scannable_id", "rfid"]
    },
    "active": {
      "type": "boolean",
      "x-eq-source-aliases": ["is_active", "current", "status", "in_service", "enabled", "state", "asset_status", "operational", "in_use", "live"],
      "x-eq-coerce": "boolean",
      "default": true
    },
    "defects_summary": {
      "type": ["string", "null"],
      "description": "Short denormalised summary of open issues against this asset. Convenience field for one-glance views — the structured per-defect records live in the asset_defect entity. Example: 'RCD board 2 to be replaced; door hinge bent'.",
      "x-eq-source-aliases": ["defects", "open_defects", "defect_summary", "outstanding_defects", "issues", "asset_issues", "problems", "faults", "defects_outstanding", "open_issues", "fault_summary"],
      "maxLength": 500
    },
    "client_classification": {
      "type": ["object", "null"],
      "description": "Customer-imposed asset taxonomy preserved verbatim. Used when a client requires their own classification scheme on their assets (e.g. data centre operator's Maximo IAM values, principal contractor's compliance taxonomy). Stays as free-form so client-specific structure isn't coerced into our canonical enums. Set programmatically by importers when a source spreadsheet carries 50+ extra columns of customer-side metadata.",
      "additionalProperties": true,
      "x-eq-source-aliases": ["client_class", "customer_taxonomy", "client_attributes", "client_metadata", "external_classification", "client_taxonomy"]
    },
    "notes": {
      "type": ["string", "null"],
      "x-eq-source-aliases": ["comment", "comments", "remarks", "note", "note_text", "observations", "additional_notes", "free_text", "general_notes", "additional_info"],
      "maxLength": 4000
    },
    "imported_at": { "type": ["string", "null"], "format": "date-time", "x-eq-system-managed": true },
    "imported_from": { "type": ["string", "null"], "x-eq-system-managed": true }
  },
  "x-eq-cross-field-rules": [
    {
      "id": "next_after_last",
      "rule": "next_service_due == null OR last_service_date == null OR next_service_due > last_service_date",
      "message": "Next service due is not after last service date."
    },
    {
      "id": "warranty_after_install",
      "rule": "warranty_expires == null OR install_date == null OR warranty_expires > install_date",
      "message": "Warranty expiry is before install date."
    }
  ],
  "x-eq-import-hints": {
    "description": "Asset registers come in wildly different shapes. The header row is rarely on row 1.",
    "common_sources": [
      {
        "name": "Existing PM contractor's register",
        "typical_columns": ["Tag", "Description", "Manufacturer", "Model", "Serial", "Last PM", "Next PM", "Frequency"],
        "watchouts": ["Often has merged header rows", "Frequency may be coded ('M', 'Q', '6M', 'A') — may need separate schedule field"]
      },
      {
        "name": "Client's facilities export (head office originated)",
        "typical_columns": ["Asset No", "Building", "Floor", "Room", "Asset Description", "Make/Model", "Install Date"],
        "watchouts": ["Building/Floor/Room often need concatenating into location_in_site", "Make/Model may be combined — needs splitting"]
      },
      {
        "name": "Hand-built electrical asset list",
        "typical_columns": ["Switchboard", "Circuit", "Description", "Amps"],
        "watchouts": ["Each row is often a sub-asset of a switchboard — parent_asset_id must be inferred from grouping"]
      }
    ]
  }
}
