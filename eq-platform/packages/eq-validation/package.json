{
  "name": "@eq/validation",
  "version": "0.0.1",
  "private": true,
  "description": "Schema-driven validation engine for EQ intake/export pipelines. Coerces, validates, and resolves FKs for canonical entities. Pure TS, no external runtime deps.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eq/schemas": "workspace:*",
    "@eq/ai": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
