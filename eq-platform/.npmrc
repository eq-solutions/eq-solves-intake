engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false

# Sandbox-only: the mounted workspace doesn't support hard links, so push the
# pnpm content-addressable store out of the mount and use the hoisted linker.
# These are safe defaults on a developer machine too — pnpm hoisted is fine.
store-dir=${HOME}/.pnpm-store
node-linker=hoisted
